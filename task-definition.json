{
    "family": "ecommerce-backend-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "ecommerce-backend",
            "image": "arn:aws:ecr:ap-southeast-2:147914448101:repository/ecommerce-backend",
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "JWT_SECRET",
                    "value": "ecommerceSecretKeyForJWTGenerationThatIsLongEnoughToBeSecure123456"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ecommerce-backend",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::147914448101:role/service-role/ecsTaskExecutionRole"
}
